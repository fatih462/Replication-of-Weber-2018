__pycache__/
*.pyc
.vscode/

weber.pdf

# Do not commit generated/intermediate data by default.
*.parquet
data/*

# Allow small public input files that are useful for reproducing tables.
!data/raw/
data/raw/*
!data/raw/F-F_Research_Data_5_Factors_2x3.csv
!data/raw/F-F_Momentum_Factor.csv
!data/raw/SENTIMENT.xlsx

# SEC filings are public, but holdings/cache files are too large for normal GitHub.
!data/sec_13f/
data/sec_13f/*
!data/sec_13f/*_manifest.json

# Allow lightweight diagnostics/provenance reports.
!data/*_report.json
!data/cleaning_report.json
